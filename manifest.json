{
  "manifest_version": 3,
  "name": "NoAI Lookup",
  "description": "Appends \"-ai\" to every Google search to filter AI results",
  "version": "1.1.2",
  "permissions": ["webNavigation", "tabs", "scripting", "storage"],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.google.com.ar/*",
    "*://*.google.com.au/*",
    "*://*.google.com.br/*",
    "*://*.google.com.co/*",
    "*://*.google.com.mx/*",
    "*://*.google.com.pe/*",
    "*://*.google.com.ph/*",
    "*://*.google.com.sg/*",
    "*://*.google.com.tr/*",
    "*://*.google.com.tw/*",
    "*://*.google.com.hk/*",
    "*://*.google.com.ua/*",
    "*://*.google.com.ng/*",
    "*://*.google.co.uk/*",
    "*://*.google.co.jp/*",
    "*://*.google.co.in/*",
    "*://*.google.co.id/*",
    "*://*.google.co.kr/*",
    "*://*.google.co.nz/*",
    "*://*.google.co.za/*",
    "*://*.google.ca/*",
    "*://*.google.de/*",
    "*://*.google.fr/*",
    "*://*.google.es/*",
    "*://*.google.it/*",
    "*://*.google.nl/*",
    "*://*.google.pl/*",
    "*://*.google.ru/*",
    "*://*.google.pt/*",
    "*://*.google.be/*",
    "*://*.google.ch/*",
    "*://*.google.at/*",
    "*://*.google.cl/*",
    "*://*.google.gr/*",
    "*://*.google.hu/*",
    "*://*.google.cz/*",
    "*://*.google.ro/*",
    "*://*.google.dk/*",
    "*://*.google.no/*",
    "*://*.google.se/*",
    "*://*.google.fi/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NoAI Lookup",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  }
}
